# Dependencies
**/node_modules/
**/venv/
**/env/
**/ENV/

# Build outputs
**/dist/
**/dist-ssr/
**/*.exe
**/*.bin
**/*.hex

# Python cache
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd

# Environment variables (Sensitive info)
**/.env
**/.env.*
!**/.env.example

# Logs
**/logs
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/pnpm-debug.log*

# IDE / Editor folders
.vscode/
.idea/
*.swp
*.swo
*.suo
.DS_Store

# Scratch / Temporary scripts
**/scratch/
**/scratch_*.py
temp/
tmp/
